# Copy this file to `.env` and fill in the values for LOCAL development:
#   cp .env.example .env
#
# `.env` is gitignored and must never be committed.
#
# For REMOTE / mobile use (Claude Code on the web), do NOT rely on this file —
# set these same keys as environment secrets in the Claude Code environment
# settings instead. The scripts read from the environment either way.

# Supabase project URL, e.g. https://heiyckeurcfjpnhmsjfo.supabase.co
SUPABASE_URL=

# Service role key — bypasses row-level security, full read/write. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string, for migrations / bulk writes.
# e.g. postgresql://postgres:PASSWORD@db.heiyckeurcfjpnhmsjfo.supabase.co:5432/postgres
SUPABASE_DB_URL=
